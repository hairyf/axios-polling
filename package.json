{
  "name": "axios-polling",
  "type": "module",
  "version": "1.1.1",
  "packageManager": "pnpm@10.28.2",
  "description": "axios polling request",
  "author": "Mr.Mao",
  "license": "ISC",
  "homepage": "https://github.com/TuiMao233/axios-polling#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TuiMao233/axios-polling.git"
  },
  "bugs": {
    "url": "https://github.com/TuiMao233/axios-polling/issues"
  },
  "keywords": [
    "axios",
    "polling",
    "axios-polling",
    "poll"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "tsx src/index.ts",
    "release": "bumpp",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "axios": ">= 0.3 || >= 1"
  },
  "dependencies": {
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@types/lodash": "^4.17.24",
    "@vitest/coverage-v8": "^4.0.18",
    "axios": "^1.13.6",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "lint-staged": "^15.4.3",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-package-exports": "^1.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
